# Copy to airflow/config/airflow.env for local use. Never commit secrets.
AIRFLOW_HOME=./.airflow
AIRFLOW__CORE__DAGS_FOLDER=./dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__DEFAULT_TIMEZONE=utc
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth
PYTHONPATH=.

RECOMART_DATABASE_URL=sqlite:///data/recomart_features.db
MLFLOW_TRACKING_URI=file:./mlruns
RECOMART_STORAGE=local
RECOMART_DATA_ROOT=data
RECOMART_REPORT_ROOT=reports
RECOMART_MODEL_ROOT=models
RECOMART_PIPELINE_SCHEDULE=
RECOMART_DVC_REMOTE=
